    <string name="gamepad_label">GamePad</string>
    <string name="gamepad_how_to_play_text">Move %1$s in different directions with the arrows on the left. Discover the combined movements by pressing the buttons on the right.\nYou can also try the fun animations and change the mouth gestures.\n The more you play, the more it can do!</string>
    <string name="timeline_label">3, 2, 1... Action!</string>
