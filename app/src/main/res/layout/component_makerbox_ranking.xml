<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/makerbox_title"
            android:gravity="center"
            android:paddingTop="@dimen/maker_box_dialog_ranking_margin_vertical"
            android:paddingBottom="@dimen/maker_box_dialog_ranking_margin_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ranking_dialog_title"/>
        <RelativeLayout
            android:paddingBottom="@dimen/maker_box_dialog_ranking_recycler_padding_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <FrameLayout
                android:id="@+id/makerbox_dialog_ranking_list_layout"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/sections_pager_box_min_height">
                <android.support.v7.widget.RecyclerView
                    android:id="@+id/makerbox_dialog_ranking_recyclerview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </FrameLayout>
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@+id/makerbox_dialog_ranking_empty_layout"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:gravity="center_horizontal"
                    android:layout_gravity="center_horizontal"
                    android:paddingLeft="@dimen/maker_box_dialog_padding_left_right"
                    android:paddingRight="@dimen/maker_box_dialog_padding_left_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/maker_box_dialog_ranking_margin_vertical"
                    android:text="@string/ranking_dialog_empty_list_description"/>
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/maker_box_dialog_ranking_margin_vertical"
                    android:src="@drawable/ranking_image"/>
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
</merge>
