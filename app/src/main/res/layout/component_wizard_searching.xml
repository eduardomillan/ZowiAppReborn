<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/search_wizard_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="@dimen/wizard_makerbox_margin_horizontal"
        android:paddingTop="@dimen/wizard_makerbox_margin_vertical"
        android:paddingRight="@dimen/wizard_makerbox_margin_horizontal"
        android:paddingBottom="@dimen/wizard_makerbox_margin_vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.bq.zowi.components.makerboxdialogs.MakerBox
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:descendantFocusability="blocksDescendants"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/searching_wizard_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/wizard_margin_bottom">
                    <TextView
                        android:textSize="@dimen/wizard_title_size"
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/wizard_makerbox_title_margin_vertical_top"
                        android:layout_marginBottom="@dimen/wizard_makerbox_title_margin_vertical_bottom"
                        android:text="@string/wizard_searching_title_text"/>
                    <TextView
                        android:textSize="@dimen/wizard_text_size"
                        android:gravity="center"
                        android:layout_gravity="center_horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/wizard_margin_bottom"
                        android:text="@string/wizard_searching_description_text"/>
                    <ProgressBar
                        android:layout_gravity="center_horizontal"
                        android:id="@+id/wizard_searching_progress_bar"
                        android:visibility="visible"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/wizard_margin_bottom"
                        android:indeterminate="true"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:id="@+id/no_zowis_found_wizard_layout"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_centerInParent="true">
                    <TextView
                        android:textSize="@dimen/wizard_title_size"
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/wizard_makerbox_title_margin_vertical_top"
                        android:layout_marginBottom="@dimen/wizard_makerbox_title_margin_vertical_bottom"
                        android:text="@string/wizard_no_zowis_found_title_text"/>
                    <TextView
                        android:textSize="@dimen/wizard_text_size"
                        android:gravity="center"
                        android:layout_gravity="center_horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/wizard_margin_bottom"
                        android:text="@string/wizard_no_zowis_found_description_text"/>
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/wizard_margin_bottom"
                        android:src="@drawable/zowi_not_found_image"
                        android:adjustViewBounds="true"/>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1">
                        <com.bq.zowi.components.makerboxdialogs.MakerBoxButton
                            android:enabled="true"
                            android:textSize="@dimen/maker_box_dialog_button_text_size"
                            android:textColor="@color/white"
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/wizard_retry_find_zowis_button"
                            android:background="@drawable/maker_box_action_button_selector"
                            android:paddingBottom="@dimen/makerbox_inner_shadow_offset"
                            android:layout_width="@dimen/makerbox_button_width"
                            android:layout_height="@dimen/makerbox_button_height"
                            android:text="@string/wizard_retry_find_zowis_button_text"
                            android:layout_centerHorizontal="true"/>
                        <TextView
                            android:textSize="@dimen/link_text_size"
                            android:textStyle="bold"
                            android:textColor="@color/link_text_selector"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:id="@+id/wizard_retry_dismiss_button"
                            android:paddingBottom="@dimen/makerbox_inner_shadow_offset"
                            android:layout_width="@dimen/makerbox_button_width"
                            android:layout_height="@dimen/makerbox_button_height"
                            android:text="@string/wizard_no_zowis_found_dismiss_button_text"/>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
        </com.bq.zowi.components.makerboxdialogs.MakerBox>
    </LinearLayout>
</RelativeLayout>
