<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:clipChildren="false"
    android:layout_width="@dimen/timeline_selected_item_width"
    android:layout_height="@dimen/timeline_recyclerview_height">
    <RelativeLayout
        android:id="@+id/selected_command_row_view_content"
        android:layout_width="@dimen/timeline_selected_item_width"
        android:layout_height="@dimen/timeline_selected_item_height">
        <ImageView
            android:id="@+id/selected_command_row_view_title_imageview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.bq.zowi.components.MultipleStatesButton
            android:id="@+id/selected_command_row_view_direction_spinner"
            android:visibility="gone"
            android:layout_width="@dimen/selected_command_multisate_button_width"
            android:layout_height="@dimen/selected_command_multisate_button_height"
            android:layout_margin="@dimen/selected_command_multiple_states_button_margin"/>
        <com.bq.zowi.components.MultipleStatesButton
            android:id="@+id/selected_command_row_view_duration_spinner"
            android:visibility="gone"
            android:layout_width="@dimen/selected_command_multisate_button_width"
            android:layout_height="@dimen/selected_command_multisate_button_height"
            android:layout_margin="@dimen/selected_command_multiple_states_button_margin"/>
        <com.bq.zowi.components.MultipleStatesButton
            android:id="@+id/selected_command_row_view_repetitions_spinner"
            android:visibility="gone"
            android:layout_width="@dimen/selected_command_multisate_button_width"
            android:layout_height="@dimen/selected_command_multisate_button_height"
            android:layout_margin="@dimen/selected_command_multiple_states_button_margin"/>
    </LinearLayout>
</LinearLayout>
