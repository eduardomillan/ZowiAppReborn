<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/activity_calibration_warning_layout"
    android:paddingLeft="@dimen/sections_pager_horizontal_margin"
    android:paddingRight="@dimen/sections_pager_horizontal_margin"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/sections_pager_vertical_margin_top">
        <RelativeLayout
            android:background="@drawable/maker_box"
            android:paddingLeft="@dimen/maker_box_dialog_padding_left_right"
            android:paddingTop="@dimen/maker_box_dialog_padding_top_bottom"
            android:paddingRight="@dimen/maker_box_dialog_padding_left_right"
            android:paddingBottom="@dimen/maker_box_dialog_padding_top_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sections_pager_box_margin"
            android:layout_marginRight="@dimen/sections_pager_box_margin"
            android:layout_weight="1">
            <TextView
                android:textSize="@dimen/sections_pager_box_title_size"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/calibration_warning_title"
                android:layout_alignParentTop="true"/>
            <TextView
                android:textSize="@dimen/project_text_size"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/calibration_warning_description"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true">
            <TextView
                android:textSize="@dimen/link_text_size"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/activity_calibration_warning_cancel_button"
                android:paddingBottom="@dimen/makerbox_inner_shadow_offset"
                android:layout_width="@dimen/calibration_bottom_button_width"
                android:layout_height="@dimen/makerbox_button_height"
                android:text="@string/calibration_warning_cancel_button"/>
            <com.bq.zowi.components.makerboxdialogs.MakerBoxButton
                android:enabled="true"
                android:textSize="@dimen/maker_box_dialog_button_text_size"
                android:textColor="@color/white"
                android:layout_gravity="center_horizontal"
                android:id="@+id/activity_calibration_warning_continue_button"
                android:background="@drawable/maker_box_action_button_selector"
                android:paddingBottom="@dimen/makerbox_inner_shadow_offset"
                android:layout_width="@dimen/calibration_bottom_button_width"
                android:layout_height="@dimen/makerbox_button_height"
                android:text="@string/calibration_warning_continue_button"
                android:layout_centerHorizontal="true"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
