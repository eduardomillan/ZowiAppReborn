<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="@dimen/achievement_row_item_height">
    <ImageView
        android:id="@+id/achievement_row_badge_image"
        android:layout_width="@dimen/achievement_row_item_badge_diameter"
        android:layout_height="@dimen/achievement_row_item_badge_diameter"
        android:layout_margin="@dimen/achievement_row_item_badge_margin"
        android:layout_centerVertical="true"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_toRightOf="@+id/achievement_row_badge_image">
        <TextView
            android:textStyle="bold"
            android:id="@+id/achievement_row_title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAllCaps="true"/>
        <TextView
            android:id="@+id/achievement_row_description_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:textStyle="italic"
            android:textColor="@color/gray_medium"
            android:id="@+id/achievement_row_unlock_condition_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</RelativeLayout>
