<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:clipChildren="false"
    android:layout_width="@dimen/timeline_selected_item_width"
    android:layout_height="@dimen/timeline_recyclerview_height"
    android:layout_margin="10dp"
    style="@style/commonListItemStyle">
    <RelativeLayout
        android:id="@+id/container"
        android:clickable="true"
        android:clipChildren="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.bq.zowi.components.timeline.SelectedCommandRowView
            android:id="@+id/selected_command_row_view_item"
            android:clipChildren="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <Button
            android:id="@+id/delete_button"
            android:background="@drawable/delete_button_selector"
            android:layout_width="@dimen/selected_command_delete_button_size"
            android:layout_height="@dimen/selected_command_delete_button_size"
            android:layout_alignParentTop="true"
            android:layout_alignParentRight="true"/>
    </RelativeLayout>
</FrameLayout>
