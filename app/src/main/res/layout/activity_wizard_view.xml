<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.bq.zowi.components.NonSwipeableViewPager
        android:id="@+id/activity_wizard_view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <include layout="@layout/component_wizard_welcome"/>
        <include layout="@layout/component_wizard_searching"/>
        <include layout="@layout/component_wizard_zowi_found"/>
        <include layout="@layout/component_wizard_connected"/>
    </com.bq.zowi.components.NonSwipeableViewPager>
    <com.bq.zowi.components.EduBar
        android:layout_gravity="bottom"
        android:id="@+id/wizard_edubar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
