<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingLeft="@dimen/sections_pager_horizontal_margin"
    android:paddingRight="@dimen/sections_pager_horizontal_margin"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.bq.zowi.components.makerboxdialogs.MakerBox
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/quiz_question_makerbox"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="@dimen/project_text_size"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/quiz_question_title_textview"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/quiz_question_answers_linearlayout"
            android:paddingBottom="@dimen/makerbox_shadow_offset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </com.bq.zowi.components.makerboxdialogs.MakerBox>
</FrameLayout>
