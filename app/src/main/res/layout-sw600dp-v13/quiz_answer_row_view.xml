<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:id="@+id/quiz_answer_row"
    android:paddingLeft="@dimen/project_quiz_answer_padding_horizontal"
    android:paddingRight="@dimen/project_quiz_answer_padding_horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/project_text_size"
        android:id="@+id/quiz_answer_row_textview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"/>
    <ImageButton
        android:id="@+id/quiz_answer_row_button"
        android:background="@drawable/select_button_selector"
        android:layout_width="@dimen/corner_button_size"
        android:layout_height="@dimen/corner_button_size"/>
</LinearLayout>
